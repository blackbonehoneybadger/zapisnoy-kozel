# DOFFA Crazy 8 — запуск на Replit.
# Import from GitHub → Run. Webview слушает порт 5173.

run = "npm install && npm run replit"
entrypoint = "src/main.tsx"
modules = ["nodejs-22"]
hidden = [".config", "node_modules", "dist", "android", ".git"]

[nix]
channel = "stable-24_05"

[env]
# Онлайн-режим (опционально): WebSocket-сервер DOFFA на Railway.
VITE_SERVER_URL = "wss://zapisnoy-kozel-production.up.railway.app"
VITE_SOLANA_NETWORK = "mainnet-beta"
# Vite / Replit proxy
HOST = "0.0.0.0"
PORT = "5173"

[packager]
language = "nodejs"
ignoredPaths = [".git", "node_modules", "dist", "android"]

[packager.features]
packageSearch = true
guessImports = false
enabledForHosting = false

# Vite → внешний порт webview (80).
[[ports]]
localPort = 5173
externalPort = 80
exposeLocalhost = true

[deployment]
# Static hosting: сборка + preview (порт 5173).
build = ["npm", "run", "build"]
run = ["npx", "vite", "preview", "--host", "0.0.0.0", "--port", "5173"]
deploymentTarget = "static"
publicDir = "dist"

[unitTest]
language = "nodejs"
