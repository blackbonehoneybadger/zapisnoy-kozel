{
  "name": "doffa-games",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "DOFFA Games — игровая платформа экосистемы DOFFA (PWA). Основной режим: DOFFA Bean Duel. Crazy 8 сохранён как скрытый режим (см. docs/CRAZY8_ARCHIVE.md).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "lint": "tsc --noEmit",
    "test": "vitest run && npm --prefix server test",
    "test:client": "vitest run",
    "cap:build": "CAP_BUILD=1 npm run build && cap sync android",
    "cap:open": "cap open android",
    "icons": "node scripts/gen-icons.mjs && capacitor-assets generate --android",
    "gen-art": "tsx scripts/gen-art.mts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "framer-motion": "^11.3.19",
    "gsap": "^3.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@google/generative-ai": "^0.24.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^1.6.1"
  }
}
