{
  "name": "zapisnoy-kozel-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Онлайн-сервер «Записной Козёл»: аккаунты, лобби, столы, авторитетная игра.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts' 'src/*.test.ts'",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@solana/web3.js": "^1.98.4",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
